rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Products can be read by anyone.
    // Authenticated users can write (needed for updating stock when orders are placed).
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders can be created/read by signed-in users.
    match /orders/{orderId} {
      // Any authenticated user can create an order.
      allow create: if request.auth != null;

      // The owner or an admin can read/update their orders
      allow read, update: if request.auth != null &&
        (request.auth.uid == resource.data.userId ||
         exists(/databases/$(database)/documents/admins/$(request.auth.uid)));

      allow delete: if false;
    }

    // Per-user cart stored under carts/{uid}
    match /carts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Users can read/write their own profile document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Admins collection itself should be read-only (managed by you)
    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false;
    }

    // Default: allow public reads, prevent all other writes
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
